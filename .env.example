# ============================================================
# 임진강김치 MES 시스템 - 환경변수 예시 파일
# 이 파일을 .env 로 복사한 후 실제 값으로 교체하세요.
# cp .env.example .env
# ============================================================

# ─────────────────────────────────────────
# MySQL 설정
# ─────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root_password_change_me
DB_HOST=mysql
DB_PORT=3306
DB_NAME=mes_db
DB_USER=mes_user
DB_PASSWORD=mes_password_change_me

# ─────────────────────────────────────────
# InfluxDB 설정 (센서 시계열 데이터)
# ─────────────────────────────────────────
INFLUXDB_PORT=8086
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=influx_password_change_me
INFLUXDB_TOKEN=imjingang-mes-super-secret-token-change-me
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=imjingang
INFLUXDB_BUCKET=mes_sensors

# ─────────────────────────────────────────
# Redis 설정 (캐시 / 세션)
# ─────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_me
REDIS_URL=redis://:redis_password_change_me@localhost:6379/0

# ─────────────────────────────────────────
# JWT / 보안 설정
# ─────────────────────────────────────────
# 운영 환경에서는 반드시 openssl rand -hex 32 로 생성하세요.
SECRET_KEY=your-super-secret-key-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─────────────────────────────────────────
# Frontend 설정
# ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api

# ─────────────────────────────────────────
# 애플리케이션 설정
# ─────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
TZ=Asia/Seoul
