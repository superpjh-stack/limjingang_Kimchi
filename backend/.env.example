# 임진강김치 MES 환경변수 설정 예제
# 이 파일을 복사하여 .env 파일을 생성하고 실제 값을 입력하세요.
# cp .env.example .env

# JWT 보안 설정
SECRET_KEY=your-very-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# MySQL 데이터베이스 설정
DB_HOST=mysql
DB_PORT=3306
DB_NAME=mes_db
DB_USER=mes_user
DB_PASSWORD=mes_password

# InfluxDB 설정 (센서 데이터)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=imjingang
INFLUXDB_BUCKET=mes_sensors

# Redis 설정 (캐싱)
REDIS_URL=redis://redis:6379
